      "targets": [
        {
          "expr": "sum by (outcome, env) (rate(satrank_probe_total{env=~\"$env\"}[5m]))",
          "legendFormat": "{{env}} {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    }
