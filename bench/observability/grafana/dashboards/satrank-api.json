  "panels": [
    {
      "id": 1,
      "title": "RPS by route",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (route, env) (rate(satrank_requests_total{env=~\"$env\", route=~\"$route\"}[1m]))",
          "legendFormat": "{{env}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "id": 2,
      "title": "Status code distribution (rps)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status, env) (rate(satrank_requests_total{env=~\"$env\", route=~\"$route\"}[1m]))",
          "legendFormat": "{{env}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 latency by route",
      "type": "timeseries",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, route, env) (rate(satrank_http_request_duration_seconds_bucket{env=~\"$env\", route=~\"$route\"}[1m])))", "legendFormat": "p50 {{env}} {{route}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, route, env) (rate(satrank_http_request_duration_seconds_bucket{env=~\"$env\", route=~\"$route\"}[1m])))", "legendFormat": "p95 {{env}} {{route}}", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le, route, env) (rate(satrank_http_request_duration_seconds_bucket{env=~\"$env\", route=~\"$route\"}[1m])))", "legendFormat": "p99 {{env}} {{route}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "id": 4,
      "title": "Error rate (4xx + 5xx / total)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (env) (rate(satrank_requests_total{env=~\"$env\", status=~\"4..|5..\"}[1m])) / clamp_min(sum by (env) (rate(satrank_requests_total{env=~\"$env\"}[1m])), 0.001)",
          "legendFormat": "{{env}} error ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []}
    },
    {
      "id": 5,
      "title": "Rate-limit rejections (rps) by limiter",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (limiter, env) (rate(satrank_rate_limit_hits_total{env=~\"$env\"}[1m]))",
          "legendFormat": "{{env}} {{limiter}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
