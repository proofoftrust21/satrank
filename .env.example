PORT=3000
HOST=0.0.0.0
NODE_ENV=development
PUBLIC_HOST=satrank.dev
# Our own public IPv4 — extra SSRF guard so a probe target that resolves to
# our ingress is rejected. Required in production; optional in development.
# SERVER_IP=198.51.100.1
DB_PATH=./data/satrank.db
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000
API_KEY=<generate with: openssl rand -hex 32>
APERTURE_SHARED_SECRET=<generate with: openssl rand -hex 32>
# HMAC used to sign internal watchlist cookies / admin-scope reads
WATCHLIST_HMAC_KEY=<generate with: openssl rand -hex 32>
OBSERVER_BASE_URL=https://api.observerprotocol.org
OBSERVER_TIMEOUT_MS=10000
LND_REST_URL=http://localhost:8080
LND_MACAROON_PATH=/app/data/readonly.macaroon
# Invoice-only macaroon for /api/deposit (distinct from readonly)
LND_INVOICE_MACAROON_PATH=/app/data/invoice.macaroon
LND_TIMEOUT_MS=30000
AUTO_INDEX_MAX_PER_MINUTE=10
# Crawl intervals (ms) — each source runs on its own timer in --cron mode
CRAWL_INTERVAL_OBSERVER_MS=300000       # 5 minutes
CRAWL_INTERVAL_LND_GRAPH_MS=3600000     # 1 hour
CRAWL_INTERVAL_LNPLUS_MS=86400000       # 24 hours
CRAWL_INTERVAL_PROBE_MS=1800000         # 30 minutes
PROBE_MAX_PER_SECOND=15
PROBE_AMOUNT_SATS=1000
# Maximum age (seconds) before /api/decide auto-triggers a fresh QueryRoutes probe
DECIDE_REPROBE_STALE_SEC=300
# /api/deposit bounds (sats). 1 sat = 1 request on paid endpoints.
DEPOSIT_MIN_SATS=21
DEPOSIT_MAX_SATS=10000
# Reporter-bonus reward loop — OFF by default, flip on day 30 if report volume < 100
REPORT_BONUS_ENABLED=false
# Node pubkey — shown in X-SatRank-Tip header so agents can open a direct channel
# NODE_PUBKEY=03your66charpubkey...
# Nostr — publish scores as NIP-85 kind 30382 events
# Generate key: npx tsx scripts/nostr-keygen.ts
# NOSTR_PRIVATE_KEY=<64-char hex>
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
NOSTR_PUBLISH_INTERVAL_MS=21600000
NOSTR_MIN_SCORE=30
