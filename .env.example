PORT=3000
HOST=0.0.0.0
NODE_ENV=development
DB_PATH=./data/satrank.db
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000
API_KEY=<generate with: openssl rand -hex 32>
APERTURE_SHARED_SECRET=<generate with: openssl rand -hex 32>
OBSERVER_BASE_URL=https://api.observerprotocol.org
OBSERVER_TIMEOUT_MS=10000
LND_REST_URL=http://localhost:8080
LND_MACAROON_PATH=/app/data/readonly.macaroon
LND_TIMEOUT_MS=30000
AUTO_INDEX_MAX_PER_MINUTE=10
# Crawl intervals (ms) — each source runs on its own timer in --cron mode
CRAWL_INTERVAL_OBSERVER_MS=300000       # 5 minutes
CRAWL_INTERVAL_LND_GRAPH_MS=3600000     # 1 hour
CRAWL_INTERVAL_LNPLUS_MS=86400000       # 24 hours
CRAWL_INTERVAL_PROBE_MS=3600000         # 1 hour
PROBE_MAX_PER_SECOND=10
PROBE_AMOUNT_SATS=1000
# Node pubkey — shown in X-SatRank-Tip header so agents can open a direct channel
# NODE_PUBKEY=03your66charpubkey...
