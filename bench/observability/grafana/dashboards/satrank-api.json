      "type": "heatmap",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 25},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (le) (rate(satrank_http_request_duration_seconds_bucket{env=~\"$env\", route=~\"$route\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {"calculate": false, "yAxis": {"unit": "s"}}
    },
    {
      "id": 7,
      "title": "Verdicts per source (rps)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
