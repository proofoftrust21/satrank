{
  "name": "satrank",
  "version": "1.0.0",
  "description": "Score de confiance pour agents IA sur Bitcoin Lightning",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "crawl": "tsx src/crawler/run.ts",
    "crawl:cron": "tsx src/crawler/run.ts --cron",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:prod": "node dist/mcp/server.js",
    "purge": "tsx src/database/purge.ts",
    "purge:prod": "node dist/database/purge.js",
    "backup": "tsx src/scripts/backup.ts",
    "backup:prod": "node dist/scripts/backup.js",
    "rollback": "tsx src/scripts/rollback.ts",
    "rollback:prod": "node dist/scripts/rollback.js",
    "calibrate": "tsx src/scripts/calibrationReport.ts",
    "bayesian:kendall": "tsx src/scripts/compareLegacyVsBayesian.ts",
    "bayesian:benchmark": "tsx src/scripts/benchmarkBayesian.ts",
    "bayesian:backfill-probe": "tsx src/scripts/backfillProbeResultsToTransactions.ts",
    "bayesian:rebuild": "tsx src/scripts/rebuildStreamingPosteriors.ts",
    "bayesian:rebuild:prod": "node dist/scripts/rebuildStreamingPosteriors.js",
    "bayesian:prune": "tsx src/scripts/pruneBayesianRetention.ts",
    "bayesian:prune:prod": "node dist/scripts/pruneBayesianRetention.js",
    "demo": "tsx src/scripts/attestationDemo.ts",
    "nostr:verify": "tsx scripts/nostr-verify.ts",
    "nostr:publish-10040": "tsx scripts/nostr-publish-10040.ts",
    "lint": "tsc --noEmit",
    "sdk:build": "cd sdk && npx tsc",
    "check-drift": "tsx scripts/check-drift.ts"
  },
  "keywords": [
    "lightning",
    "l402",
    "trust-score",
    "agents"
  ],
  "license": "AGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^11.7.0",
    "bolt11": "^1.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "nostr-tools": "^2.23.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "undici": "^6.25.0",
    "uuid": "^11.1.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
